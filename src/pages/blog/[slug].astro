---
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/blog/Breadcrumbs.astro";
import BlogCard from "../../components/blog/BlogCard.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const { post } = Astro.props;
const { Content } = await render(post);
const relatedPosts = posts.filter((entry) => entry.slug !== post.slug).slice(0, 2);

const published = new Intl.DateTimeFormat("en", {
  month: "long",
  day: "numeric",
  year: "numeric",
}).format(post.data.pubDate);
---

<Base title={post.data.title}>
  <article class="mx-auto max-w-4xl px-6 py-20">
    <Breadcrumbs
      items={[
        { label: "Inicio", href: "/" },
        { label: "Blog", href: "/blog" },
        { label: post.data.title },
      ]}
    />

    <Image
      src={post.data.cover}
      alt={post.data.coverAlt}
      class="mb-8 h-[28rem] w-full rounded-3xl object-cover shadow-lg"
      loading="eager"
    />

    <div class="mb-4 flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.2em] text-emerald-600">
      <span>{published}</span>
      <span class="h-1 w-1 rounded-full bg-emerald-400"></span>
      <span>{post.data.author}</span>
    </div>

    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 md:text-4xl">
      {post.data.title}
    </h1>

    <div class="prose prose-lg prose-emerald mt-8 max-w-none text-slate-700">
      <Content />
    </div>

    <a
      href="/blog"
      class="mt-8 inline-flex items-center gap-2 rounded-full bg-emerald-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-emerald-700"
    >
      Back to blog
    </a>

    {
      relatedPosts.length > 0 && (
        <section class="mt-16">
          <h2 class="mb-6 text-2xl font-bold tracking-tight text-slate-900 md:text-3xl">
            Related articles
          </h2>

          <div class="grid gap-6 md:grid-cols-2">
            {relatedPosts.map((relatedPost) => (
              <BlogCard post={relatedPost} />
            ))}
          </div>
        </section>
      )
    }
  </article>
</Base>
