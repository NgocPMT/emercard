---
import "../styles/global.css";
import { Font } from "astro:assets";

const features = [
  {
    tag: "Chạm / quét",
    title: "NFC và QR cùng mở một hồ sơ",
    body: "Chạm điện thoại vào thẻ hoặc quét mã QR để đi đến cùng một hồ sơ khẩn cấp, nên không cần giải thích nhiều bước khi đang vội.",
  },
  {
    tag: "Hồ sơ y tế",
    title: "Bệnh nền, dị ứng, thuốc đang dùng",
    body: "Người dùng có thể lưu và cập nhật các thông tin quan trọng như bệnh nền, dị ứng thuốc, dị ứng thực phẩm, thuốc đang dùng và lịch sử điều trị.",
  },
  {
    tag: "Liên hệ",
    title: "Người thân và người hỗ trợ luôn rõ ràng",
    body: "Thông tin liên hệ khẩn cấp được đặt cạnh hồ sơ y tế để người hỗ trợ hoặc nhân viên y tế có thể liên lạc nhanh khi cần.",
  },
  {
    tag: "Theo dõi",
    title: "Cập nhật online, ghi nhận truy cập",
    body: "Dữ liệu được cập nhật theo thời gian thực qua website, lưu trên đám mây, và hệ thống ghi nhận lịch sử mở hồ sơ để chủ tài khoản nắm được.",
  },
];

const audience = [
  {
    tag: "Người cao tuổi",
    title: "Giữ hồ sơ y tế ở đúng nơi dễ lấy nhất",
    body: "Thẻ nhỏ gọn, dễ mang theo trong ví, giúp người dùng cao tuổi không phải nhớ nhiều thao tác hay mở ứng dụng phức tạp.",
  },
  {
    tag: "Bệnh mạn tính",
    title: "Thông tin dị ứng và thuốc luôn sẵn",
    body: "Bệnh nền, dị ứng thuốc, dị ứng thực phẩm và thuốc đang dùng đều có thể được lưu để nhân viên y tế nắm nhanh trong tình huống khẩn cấp.",
  },
  {
    tag: "Sống một mình",
    title: "Có một đường liên hệ khẩn cấp rõ ràng",
    body: "EmerCard giúp người dùng sống một mình vẫn có kênh gọi hỗ trợ nhanh tới người thân hoặc người chăm sóc khi cần.",
  },
  {
    tag: "Gia đình & người chăm sóc",
    title: "Dễ cập nhật, dễ theo dõi, dễ yên tâm",
    body: "Người thân có thể cập nhật hồ sơ online, quản lý lịch sử truy cập và biết rằng thông tin quan trọng luôn mới nhất.",
  },
];

const techRows = [
  ["Công nghệ kết nối", "NFC + mã QR"],
  ["Chip NFC", "NTAG 216"],
  ["Khả năng tương thích", "Android, iPhone"],
  ["Phương thức truy cập", "Chạm NFC hoặc quét mã QR"],
  ["Cập nhật dữ liệu", "Theo thời gian thực thông qua website"],
  ["Lưu trữ dữ liệu", "Cơ sở dữ liệu đám mây"],
  ["Bảo mật", "Mã hóa dữ liệu người dùng"],
];

const kitItems = [
  "01 thẻ NFC EmerCard",
  "01 tài liệu hướng dẫn sử dụng",
  "Hộp giấy thân thiện với môi trường",
  "Mã QR cá nhân hóa và mã định danh người dùng",
  "Logo và bộ nhận diện EmerCard / Emerlink",
];
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="EmerCard là thẻ định danh y tế khẩn cấp tích hợp NFC và QR, cho phép mở hồ sơ sức khỏe được cấp quyền, cập nhật trực tuyến và theo dõi truy cập rõ ràng."
    />
    <title>EmerCard · Đăng ký chờ ra mắt</title>
    <Font cssVariable="--font-nunito" preload />
    <Font cssVariable="--font-inconsolata" preload />
  </head>
  <body class="[font-family:var(--font-nunito)] scroll-smooth bg-slate-50 text-slate-900 antialiased">
    <div class="relative isolate overflow-hidden">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[34rem] bg-[radial-gradient(circle_at_10%_0%,rgba(16,185,129,0.10),transparent_28%),radial-gradient(circle_at_100%_14%,rgba(20,184,166,0.09),transparent_26%)]"></div>
      <div class="pointer-events-none absolute -left-24 top-28 h-96 w-96 rounded-full bg-emerald-400/10 blur-3xl"></div>
      <div class="pointer-events-none absolute right-0 top-[24rem] h-[32rem] w-[32rem] rounded-full bg-teal-400/10 blur-3xl"></div>

      <header class="sticky top-0 z-20 border-b border-slate-200/80 bg-white/75 backdrop-blur-md">
        <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-6 py-4">
          <a href="#top" class="flex items-center gap-3" aria-label="Trang chủ EmerCard">
            <img src="/logo.png" alt="EmerCard" class="h-10 w-10 rounded-2xl border border-slate-200 bg-white object-contain shadow-sm" />
            <span class="text-lg font-extrabold tracking-tight text-slate-900">EmerCard</span>
          </a>

          <nav aria-label="Điều hướng chính" class="hidden items-center gap-6 md:flex">
            <a href="#top" class="text-sm font-medium text-slate-600 transition hover:text-emerald-700">Tổng quan</a>
            <a href="#proof" class="text-sm font-medium text-slate-600 transition hover:text-emerald-700">Điểm nổi bật</a>
            <a href="#specs" class="text-sm font-medium text-slate-600 transition hover:text-emerald-700">Thông số</a>
            <a href="#audience" class="text-sm font-medium text-slate-600 transition hover:text-emerald-700">Đối tượng</a>
            <a href="#join" class="text-sm font-medium text-slate-600 transition hover:text-emerald-700">Chờ ra mắt</a>
          </nav>

          <a
            href="#join"
            class="inline-flex items-center justify-center rounded-full border border-slate-200 bg-white px-5 py-2.5 text-sm font-semibold text-slate-900 shadow-sm transition hover:border-emerald-300 hover:text-emerald-700"
          >
            Đăng ký
          </a>
        </div>
      </header>

      <main id="top" class="relative">
        <section class="py-20 md:py-28">
          <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 lg:grid-cols-[1.05fr_0.95fr]">
            <div class="flex flex-col gap-7">
              <p class="text-sm font-extrabold uppercase tracking-[0.14em] text-emerald-600">Kết nối khẩn cấp</p>

              <div class="space-y-5">
                <h1 class="max-w-3xl text-4xl font-black leading-[0.98] tracking-tight text-slate-900 md:text-6xl">
                  Một chạm để mở hồ sơ y tế khi từng giây đều quan trọng.
                </h1>
                <p class="max-w-2xl text-lg leading-8 text-slate-600 md:text-xl">
                  EmerCard là thẻ định danh y tế khẩn cấp tích hợp NFC và mã QR. Người dùng, người thân hoặc nhân viên y tế có thể mở hồ sơ sức khỏe được cấp quyền ngay trên website, trong khi dữ liệu vẫn được cập nhật trực tuyến theo thời gian thực.
                </p>
              </div>

              <div class="flex flex-wrap gap-3">
                <a
                  href="#join"
                  class="inline-flex items-center justify-center rounded-full bg-emerald-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-700"
                >
                  Đăng ký chờ ra mắt
                </a>
                <a
                  href="#specs"
                  class="inline-flex items-center justify-center rounded-full border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:border-slate-400 hover:text-emerald-700"
                >
                  Xem thông số
                </a>
              </div>

              <div class="flex flex-wrap gap-2" aria-label="Thông tin nổi bật">
                <span class="inline-flex items-center rounded-full border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-slate-600 shadow-sm">Thẻ PVC chống nước</span>
                <span class="inline-flex items-center rounded-full border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-slate-600 shadow-sm">Chip NTAG216</span>
                <span class="inline-flex items-center rounded-full border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-slate-600 shadow-sm">Android · iPhone</span>
                <span class="inline-flex items-center rounded-full border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-slate-600 shadow-sm">Mã hóa dữ liệu người dùng</span>
              </div>
            </div>

            <div class="relative min-h-[38rem] ">
              <div class="absolute -right-8 -top-8 h-44 w-44 rounded-full bg-emerald-400/10 blur-3xl"></div>
              <div class="absolute -bottom-12 -left-10 h-52 w-52 rounded-full bg-teal-400/10 blur-3xl"></div>

              <article class="absolute left-6 top-8 w-[78%] -rotate-6 overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-2xl">
                <img src="/mockup-2.png" alt="EmerCard mockup" class="h-72 w-full object-cover" loading="eager" fetchpriority="high" />
              </article>

              <article class="absolute bottom-16 right-6 w-[78%] overflow-hidden rounded-[1.75rem] border border-slate-200 bg-slate-950 text-white shadow-2xl">
                <img src="/mockup-1.png" alt="EmerCard mockup" class="h-64 w-full object-cover opacity-90" loading="eager" />
              </article>
            </div>
          </div>
        </section>

        <section id="proof" class="border-t border-slate-200/80 py-20 md:py-24">
          <div class="mx-auto flex max-w-7xl flex-col gap-12 px-6">
            <div class="max-w-2xl space-y-4">
              <p class="text-sm font-extrabold uppercase tracking-[0.14em] text-emerald-600">Cách EmerCard làm việc</p>
              <h2 class="text-3xl font-black tracking-tight text-slate-900 md:text-4xl">Thông tin quan trọng được đưa lên trước, không để người dùng phải lục tìm.</h2>
            </div>

            <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
              {features.map((feature, index) => (
                <article class="flex h-full flex-col gap-4 rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-lg">
                  <div class="flex h-11 w-11 items-center justify-center rounded-2xl border border-slate-200 bg-slate-50 text-sm font-extrabold text-emerald-700">
                    0{index + 1}
                  </div>
                  <span class="inline-flex w-fit rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-semibold text-slate-600">{feature.tag}</span>
                  <h3 class="text-2xl font-extrabold tracking-tight text-slate-900">{feature.title}</h3>
                  <p class="text-sm leading-6 text-slate-600">{feature.body}</p>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="specs" class="border-t border-slate-200/80 py-20 md:py-24">
          <div class="mx-auto grid max-w-7xl gap-10 px-6">
            <article class="rounded-[2rem] border border-slate-200 bg-white p-7 shadow-sm md:p-8">
              <div class="space-y-4">
                <p class="text-sm font-extrabold uppercase tracking-[0.14em] text-emerald-600">Thông số kỹ thuật</p>
                <h2 class="text-3xl font-black tracking-tight text-slate-900">Thẻ vật lý, nền tảng số, dữ liệu luôn mới.</h2>
                <p class="text-base leading-7 text-slate-600">Dưới đây là các thông số chính của EmerCard, tập trung vào tính tương thích, khả năng truy cập và cách dữ liệu được quản lý.</p>
              </div>

              <table class="[font-family:var(--font-inconsolata)] mt-8 w-full border-collapse text-sm">
                <thead>
                  <tr class="border-b border-slate-200 text-left text-xs uppercase tracking-[0.12em] text-slate-500">
                    <th class="py-3 pr-4 font-bold">Hạng mục</th>
                    <th class="py-3 text-right font-bold">Thông tin</th>
                  </tr>
                </thead>
                <tbody>
                  {techRows.map(([label, value]) => (
                    <tr class="border-b border-slate-200 last:border-b-0">
                      <td class="py-4 pr-4 text-slate-700">{label}</td>
                      <td class="py-4 text-right text-slate-900">{value}</td>
                    </tr>
                  ))}
                </tbody>
              </table>

              <div class="mt-8 space-y-3">
                <p class="text-sm font-extrabold uppercase tracking-[0.14em] text-emerald-600">Trong bộ sản phẩm</p>
                <ul class="space-y-3">
                  {kitItems.map((item) => (
                    <li class="flex items-start gap-3 text-sm leading-6 text-slate-700 before:mt-2 before:h-2 before:w-2 before:flex-none before:rounded-full before:bg-emerald-600 before:content-['']">
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          </div>
        </section>

        <section id="audience" class="border-t border-slate-200/80 py-20 md:py-24">
          <div class="mx-auto flex max-w-7xl flex-col gap-12 px-6">
            <div class="max-w-2xl space-y-4">
              <p class="text-sm font-extrabold uppercase tracking-[0.14em] text-emerald-600">Phù hợp cho ai</p>
              <h2 class="text-3xl font-black tracking-tight text-slate-900 md:text-4xl">Thiết kế cho những người cần thông tin y tế sẵn sàng trong túi.</h2>
            </div>

            <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
              {audience.map((item) => (
                <article class="flex h-full flex-col gap-4 rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-lg">
                  <span class="inline-flex w-fit rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-semibold text-slate-600">{item.tag}</span>
                  <h3 class="text-2xl font-extrabold tracking-tight text-slate-900">{item.title}</h3>
                  <p class="text-sm leading-6 text-slate-600">{item.body}</p>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="join" class="border-t border-slate-200/80 py-20 md:py-24">
          <div class="mx-auto grid max-w-7xl gap-10 px-6 lg:grid-cols-[1.05fr_0.95fr]">
            <div class="rounded-[2rem] border border-slate-200 bg-gradient-to-b from-white to-emerald-50 p-7 shadow-sm md:p-8">
              <div class="space-y-4">
                <p class="text-sm font-extrabold uppercase tracking-[0.14em] text-emerald-600">Chờ ra mắt</p>
                <h2 class="text-3xl font-black tracking-tight text-slate-900">Nhận thông báo khi EmerCard mở đợt đăng ký đầu tiên.</h2>
                <p class="text-base leading-7 text-slate-600">Chúng tôi sẽ gửi ảnh sản phẩm, bản xem trước hồ sơ điện tử và hướng dẫn thiết lập ngay khi waitlist mở. Nội dung phù hợp cho người dùng cá nhân, gia đình và đội ngũ chăm sóc.</p>
              </div>

              <div class="mt-8 space-y-0 overflow-hidden rounded-[1.5rem] border border-slate-200 bg-white">
                <div class="grid gap-0 md:grid-cols-[170px_1fr]">
                  <div class="border-b border-slate-200 p-5 text-xs font-extrabold uppercase tracking-[0.12em] text-slate-500 md:border-b-0 md:border-r">Ảnh sản phẩm</div>
                  <p class="border-b border-slate-200 p-5 text-sm leading-6 text-slate-600 md:border-b-0">Xem lại logo, thẻ vật lý, và các hình ảnh sản phẩm trước khi quyết định.</p>
                </div>
                <div class="grid gap-0 md:grid-cols-[170px_1fr]">
                  <div class="border-b border-slate-200 p-5 text-xs font-extrabold uppercase tracking-[0.12em] text-slate-500 md:border-b-0 md:border-r">Bản xem trước</div>
                  <p class="border-b border-slate-200 p-5 text-sm leading-6 text-slate-600 md:border-b-0">Nhận bản preview của hồ sơ sức khỏe, các trường thông tin và cách cập nhật dữ liệu.</p>
                </div>
                <div class="grid gap-0 md:grid-cols-[170px_1fr]">
                  <div class="p-5 text-xs font-extrabold uppercase tracking-[0.12em] text-slate-500 md:border-r">Hướng dẫn</div>
                  <p class="p-5 text-sm leading-6 text-slate-600">Tài liệu thiết lập ngắn gọn để bắt đầu nhanh và không bị rối khi mở đợt đầu.</p>
                </div>
              </div>

              <p class="mt-4 text-sm leading-6 text-slate-500">Không spam. Chỉ gửi thông tin ra mắt và cập nhật quan trọng liên quan đến sản phẩm.</p>
            </div>

            <form class="flex flex-col justify-center rounded-4xl border border-slate-200 bg-white p-7 shadow-sm md:p-8" id="waitlist-form">
              <div class="space-y-5">
                <div class="space-y-4">
                  <p class="text-sm font-extrabold uppercase tracking-[0.14em] text-emerald-600">Đăng ký</p>
                  <h2 class="text-3xl font-black tracking-tight text-slate-900">Chỉ cần email để bắt đầu.</h2>
                </div>

                <label class="block space-y-2" for="email">
                  <span class="text-sm font-semibold text-slate-700">Email của bạn</span>
                  <input
                    class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-emerald-500 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                    id="email"
                    name="email"
                    type="email"
                    placeholder="ten@domain.com"
                    autocomplete="email"
                    required
                  />
                </label>

                <div class="flex flex-wrap items-center gap-3">
                  <button type="submit" class="inline-flex items-center justify-center rounded-full bg-slate-900 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-800">
                    Nhận thông báo
                  </button>
                  <span class="text-sm font-medium text-slate-500">Chỉ cần email để bắt đầu.</span>
                </div>

                <div id="waitlist-status" class="min-h-6 text-sm text-slate-500" aria-live="polite"></div>
              </div>
              <img class="rounded-3xl" src="/cover-01.png" alt="call to action cover"/>
            </form>
          </div>
        </section>
      </main>

      <footer class="border-t border-slate-200/80 py-6 text-sm text-slate-500">
        <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-3 px-6">
          <span>© EmerCard · kết nối khẩn cấp</span>
          <span class="font-medium">NFC, QR và thông tin y tế được cấp quyền</span>
        </div>
      </footer>
    </div>
  </body>
</html>
